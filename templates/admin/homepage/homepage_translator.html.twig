{% extends '@XutimCore/admin/base.html.twig' %}
{% import '@XutimCore/admin/common/badges.html.twig' as badges %}
{% import '@XutimCore/admin/common/translatable.html.twig' as translatable %}

{% block pageTitle %}{{ 'Dashboard'|trans({}, 'admin')|capitalize }}{% endblock %}

{% block breadcrumbHeader %}
    <twig:Xutim:Admin:Breadcrumbs>
        <li class="breadcrumb-item">Dashboard</li>
    </twig:Xutim:Admin:Breadcrumbs>
{% endblock %}

{% block body %}
    {% if translationStats is not empty %}
        <div class="row row-cards mb-4">
            {% for stat in translationStats %}
                <div class="col-sm-6 col-lg-3">
                    {% set singleLocale = stat.localeBreakdown|length == 1 %}
                    {% set typeCount = (stat.untranslatedCount > 0 ? 1 : 0) + (stat.outdatedCount > 0 ? 1 : 0) + (stat.unpublishedCount > 0 ? 1 : 0) %}
                    {% set cardUrl = (singleLocale and typeCount <= 1) ? stat.localeBreakdown[0].url : (stat.localeBreakdown is empty ? stat.listUrl : null) %}

                    {% if cardUrl %}
                        <a href="{{ cardUrl }}" class="card card-link text-decoration-none">
                    {% else %}
                        <div class="card" style="transition: box-shadow .15s ease;" onmouseover="this.style.boxShadow='0 .5rem 1rem rgba(0,0,0,.1)'" onmouseout="this.style.boxShadow=''">
                    {% endif %}
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-3{{ stat.localeBreakdown|length > 1 ? ' mb-3' : '' }}">
                                <span class="avatar avatar-md rounded-circle bg-primary-lt" style="box-shadow: none;">
                                    <twig:ux:icon :name="stat.icon" class="icon text-primary" />
                                </span>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="fw-bold text-uppercase small" style="letter-spacing: 0.05em;">{{ stat.label|capitalize }}</div>
                                    <div class="d-flex align-items-baseline flex-wrap gap-2">
                                        <span class="h2 mb-0">{{ stat.totalCount }}</span>
                                        {% if typeCount > 1 %}
                                            <span class="d-flex align-items-center gap-2 ms-auto text-secondary">
                                                {% if stat.untranslatedCount > 0 %}
                                                    <a href="{{ stat.untranslatedUrl ?? stat.listUrl }}" class="d-inline-flex align-items-center gap-1 text-secondary text-decoration-none" title="{{ 'to translate'|trans({}, 'admin') }}" data-controller="tooltip">
                                                        <twig:ux:icon name="tabler:language" style="width: 1em; height: 1em;" />{{ stat.untranslatedCount }}
                                                    </a>
                                                {% endif %}
                                                {% if stat.outdatedCount > 0 %}
                                                    <a href="{{ stat.outdatedUrl ?? stat.listUrl }}" class="d-inline-flex align-items-center gap-1 text-secondary text-decoration-none" title="{{ 'to update'|trans({}, 'admin') }}" data-controller="tooltip">
                                                        <twig:ux:icon name="tabler:refresh-alert" style="width: 1em; height: 1em;" />{{ stat.outdatedCount }}
                                                    </a>
                                                {% endif %}
                                                {% if stat.unpublishedCount > 0 %}
                                                    <a href="{{ stat.unpublishedUrl ?? stat.listUrl }}" class="d-inline-flex align-items-center gap-1 text-secondary text-decoration-none" title="{{ 'to publish'|trans({}, 'admin') }}" data-controller="tooltip">
                                                        <twig:ux:icon name="tabler:send" style="width: 1em; height: 1em;" />{{ stat.unpublishedCount }}
                                                    </a>
                                                {% endif %}
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            {% if stat.localeBreakdown|length > 1 %}
                                <div class="d-flex flex-wrap gap-1">
                                    {% for localeStat in stat.localeBreakdown %}
                                        <a href="{{ localeStat.url }}"
                                           class="badge bg-primary-lt text-decoration-none"
                                        >
                                            {{ localeStat.locale|upper }}: <span class="fw-bold">{{ localeStat.count }}</span>
                                        </a>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    {% if cardUrl %}
                        </a>
                    {% else %}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {% if latestNotifications is not empty %}
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">{{ 'Unread notifications'|trans({}, 'admin') }}</h3>
                <div class="card-actions">
                    <a href="{{ admin_path('admin_notification_list') }}" class="btn btn-link">{{ 'View all'|trans({}, 'admin') }}</a>
                </div>
            </div>
            <div class="list-group list-group-flush">
                {% for notification in latestNotifications %}
                    <form method="post" action="{{ admin_path('admin_notification_read', {id: notification.id}) }}">
                        <button type="submit" class="list-group-item list-group-item-action w-100 text-start border-0">
                            <div class="d-flex justify-content-between align-items-center gap-2">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="status-dot status-dot-animated status-{{ notification.severity.statusColor() }}"></span>
                                    <div>
                                        <div class="fw-semibold">{{ notification.title }}</div>
                                        <div class="text-secondary small mt-1">{{ notification.body|u.truncate(80, '...') }}</div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-secondary text-nowrap small">{{ notification.createdAt|format_datetime('short', 'short') }}</span>
                                    <span class="badge bg-danger text-white">new</span>
                                </div>
                            </div>
                        </button>
                    </form>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    <div class="row row-cards">
        <div class="col-md-12 col-lg-6">
            <turbo-frame id="untranslated-articles" data-turbo-action="advance">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        {{ 'Articles to translate'|trans({}, 'admin') }}
                    </h3>
                </div>
                <div class="card-table table-responsive">
                    <table class="table table-vcenter">
                        <thead>
                            <tr>
                                <th title="{{ 'publication status'|trans({}, 'admin')|capitalize }}" data-controller="tooltip">S</th>
                                <th>{{ 'title'|trans({}, 'admin')|capitalize }}</th>
                                <th>{{ 'created at'|trans({}, 'admin')|capitalize }}</th>
                                {% if userLocales|length > 1 %}
                                    <th>{{ 'missing languages'|trans({}, 'admin')|capitalize }}</th>
                                {% endif %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for article in untranslatedPager %}
                                {% set translation = article.translationByLocaleOrAny(content_context_language(), referenceLocale) %}
                                {% set firstMissingLocale = null %}
                                {% for userLocale in userLocales %}
                                    {% if firstMissingLocale is null
                                        and article.translations|reduce((carry, t) => carry == true or userLocale == t.locale) == false
                                        and (article.translationLocales is empty or article.isLocaleAllowed(userLocale)) %}
                                        {% set firstMissingLocale = userLocale %}
                                    {% endif %}
                                {% endfor %}
                                <tr>
                                    <td>{{ badges.publicationStatusBadge(translation) }}</td>
                                    <td class="text-wrap">
                                        <a href="{{ admin_path('admin_article_edit', {id: article.id, _content_locale: firstMissingLocale}) }}"
                                           data-turbo-frame="_top" class="btn-link mt-1 text-dark">
                                            {{ translatable.languageBadge(translation) }}
                                            {{ translation.title }}
                                        </a>
                                    </td>
                                    <td class="text-secondary text-nowrap">
                                        <twig:Xutim:Admin:Icon name="calendar" />
                                        {{ article.createdAt|format_date }}
                                    </td>
                                    {% if userLocales|length > 1 %}
                                        <td>
                                            <div class="tags-list d-inline">
                                                {% for userLocale in userLocales %}
                                                    {% if article.translations|reduce((carry, translation) => carry == true or userLocale == translation.locale) == false %}
                                                        {% set allowed = article.translationLocales is empty or article.isLocaleAllowed(userLocale) %}
                                                        <span class="tag{{ not allowed ? ' opacity-50' : '' }}" {% if not allowed %}title="{{ 'not translatable'|trans({}, 'admin') }}"{% endif %}>
                                                            {{ userLocale }}
                                                            {% if not allowed %}<small class="text-muted">&times;</small>{% endif %}
                                                        </span>
                                                    {% endif %}
                                                {% endfor %}
                                            </div>
                                        </td>
                                    {% endif %}
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if untranslatedPager.nbPages > 1 %}
                    <div class="card-footer d-flex align-items-center border-top">
                        <p class="m-0 text-muted">{{ 'page'|trans({}, 'admin')|capitalize }} {{ untranslatedPager.currentPage }} {{ 'of'|trans({}, 'admin') }} {{ untranslatedPager.nbPages }}</p>
                        <ul class="pagination m-0 ms-auto">
                            <li class="page-item{{ not untranslatedPager.hasPreviousPage ? ' disabled' }}">
                                <a href="{{ untranslatedPager.hasPreviousPage ? admin_current_path_with({untranslatedPage: untranslatedPager.previousPage}) : '#' }}" class="page-link">
                                    <twig:Xutim:Admin:Icon name="chevron-left" /> {{ 'prev'|trans({}, 'admin') }}
                                </a>
                            </li>
                            <li class="page-item{{ not untranslatedPager.hasNextPage ? ' disabled' }}">
                                <a href="{{ untranslatedPager.hasNextPage ? admin_current_path_with({untranslatedPage: untranslatedPager.nextPage}) : '#' }}" class="page-link">
                                    {{ 'next'|trans({}, 'admin') }} <twig:Xutim:Admin:Icon name="chevron-right" />
                                </a>
                            </li>
                        </ul>
                    </div>
                {% endif %}
            </div>
            </turbo-frame>
        </div>

        <div class="col-md-12 col-lg-6">
            <turbo-frame id="changed-articles" data-turbo-action="advance">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        {{ 'Articles to update'|trans({}, 'admin') }}
                    </h3>
                </div>
                <div class="card-table table-responsive">
                    <table class="table table-vcenter">
                        <thead>
                            <tr>
                                <th title="{{ 'publication status'|trans({}, 'admin') }}">S</th>
                                <th>{{ 'title'|trans({}, 'admin') }}</th>
                                <th>{{ 'updated at'|trans({}, 'admin') }}</th>
                                {% if userLocales|length > 1 %}
                                    <th>{{ 'languages changed'|trans({}, 'admin') }}</th>
                                {% endif %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for article in changedPager %}
                                {% set translation = article.translationByLocaleOrAny(content_context_language(), referenceLocale) %}
                                {% set refTrans = article.getTranslationByLocale(referenceLocale) %}
                                {% set effectiveRef = refTrans ?? article.defaultTranslation %}
                                {% set firstOutdatedLocale = null %}
                                {% for t in article.translations %}
                                    {% if firstOutdatedLocale is null and t.locale in userLocales and t.locale != referenceLocale
                                        and (t.referenceSyncedAt is null or t.referenceSyncedAt < effectiveRef.updatedAt) %}
                                        {% set firstOutdatedLocale = t.locale %}
                                    {% endif %}
                                {% endfor %}
                                <tr>
                                    <td>{{ badges.publicationStatusBadge(translation) }}</td>
                                    <td class="text-wrap">
                                        <a href="{{ admin_path('admin_article_edit', {id: article.id, _content_locale: firstOutdatedLocale}) }}"
                                           data-turbo-frame="_top" class="btn-link mt-1 text-dark">
                                            {{ translatable.languageBadge(translation) }}
                                            {{ translation.title }}
                                        </a>
                                    </td>
                                    <td class="text-secondary text-nowrap">
                                        <twig:Xutim:Admin:Icon name="calendar" />
                                        {{ effectiveRef.updatedAt|format_date }}
                                    </td>
                                    {% if userLocales|length > 1 %}
                                        <td>
                                            <div class="tag-list">
                                                {% for t in article.translations %}
                                                    {% if t.locale in userLocales and t.locale != referenceLocale
                                                        and (t.referenceSyncedAt is null or t.referenceSyncedAt < effectiveRef.updatedAt) %}
                                                        <span class="tag">{{ t.locale }}</span>
                                                    {% endif %}
                                                {% endfor %}
                                            </div>
                                        </td>
                                    {% endif %}
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if changedPager.nbPages > 1 %}
                    <div class="card-footer d-flex align-items-center border-top">
                        <p class="m-0 text-muted">{{ 'page'|trans({}, 'admin')|capitalize }} {{ changedPager.currentPage }} {{ 'of'|trans({}, 'admin') }} {{ changedPager.nbPages }}</p>
                        <ul class="pagination m-0 ms-auto">
                            <li class="page-item{{ not changedPager.hasPreviousPage ? ' disabled' }}">
                                <a href="{{ changedPager.hasPreviousPage ? admin_current_path_with({changedPage: changedPager.previousPage}) : '#' }}" class="page-link">
                                    <twig:Xutim:Admin:Icon name="chevron-left" /> {{ 'prev'|trans({}, 'admin') }}
                                </a>
                            </li>
                            <li class="page-item{{ not changedPager.hasNextPage ? ' disabled' }}">
                                <a href="{{ changedPager.hasNextPage ? admin_current_path_with({changedPage: changedPager.nextPage}) : '#' }}" class="page-link">
                                    {{ 'next'|trans({}, 'admin') }} <twig:Xutim:Admin:Icon name="chevron-right" />
                                </a>
                            </li>
                        </ul>
                    </div>
                {% endif %}
            </div>
            </turbo-frame>
        </div>
    </div>

{% endblock %}
