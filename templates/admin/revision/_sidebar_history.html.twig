<turbo-frame id="sidebar-history">
    <div class="list-group list-group-flush">
        {% set latestComparable = null %}
        {% for event in events %}
            {% if latestComparable is null and is_comparable_event(event) %}
                {% set latestComparable = event %}
            {% endif %}
        {% endfor %}

        {% for event in events|slice(0, 10) %}
            {% set userData = usersData[event.userIdentifier]|default({}) %}
            {% set canLink = is_comparable_event(event) and latestComparable is not null %}
            {% if canLink %}
                <a
                    href="{{ admin_path('admin_content_translation_revisions', {id: translationId, oldId: event.id, newId: latestComparable.id}) }}"
                    class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2"
                    data-turbo-frame="_top"
                >
            {% else %}
                <div class="list-group-item d-flex align-items-center gap-2 py-2">
            {% endif %}
                <span
                    class="avatar avatar-xs"
                    {% if userData.avatar|default('') %}
                    style="background-image: url({{ userData.avatar }})"
                    {% endif %}
                ></span>
                <div class="flex-fill">
                    <div class="small fw-semibold">
                        {{ event.recordedAt|date('d M H:i') }}
                    </div>
                    <div class="small text-secondary">
                        {% if not is_content_event(event) %}
                            <span class="badge bg-muted-lt">{{ revision_event_label(event) }}</span>
                        {% endif %}
                        {{ userData.name|default(event.userIdentifier) }}
                    </div>
                </div>
            {% if canLink %}
                </a>
            {% else %}
                </div>
            {% endif %}
        {% else %}
            <div class="p-3 text-muted small">
                {{ 'No revision history'|trans({}, 'admin') }}
            </div>
        {% endfor %}
    </div>
    {% if events|length > 10 %}
        <a
            href="{{ admin_path('admin_content_translation_revisions', {id: translationId}) }}"
            class="small d-block text-center py-2 border-top"
            data-turbo-frame="_top"
        >
            {{ 'View all {count} revisions'|trans({'{count}': events|length}, 'admin') }}
        </a>
    {% endif %}
</turbo-frame>
