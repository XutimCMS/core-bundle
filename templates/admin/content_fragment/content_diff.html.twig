{% macro wrapper_class(op) %}
    {% if op == 'added' %}block-added
    {% elseif op == 'removed' %}block-removed
    {% elseif op == 'modified_text' or op == 'modified' %}block-modified
    {% else %}block-unchanged{% endif %}
{% endmacro %}

{% macro tune_changes(meta) %}
    {% if meta %}
        {% for key, field in meta %}
            {% if field.status is defined and field.status == 'changed' %}
                <div class="small text-muted mt-1">
                    <span class="badge bg-secondary-lt">{{ key }}</span>
                    <del class="text-danger">{{ field.old }}</del>
                    →
                    <ins class="text-success">{{ field.new }}</ins>
                </div>
            {% endif %}
        {% endfor %}
    {% endif %}
{% endmacro %}

{% import _self as diff %}

{% for row in rows %}
    {% set op = row.op %}
    {% set meta = row.meta is defined ? row.meta : null %}
    {% set props = row.props is defined ? row.props : null %}
    {% set hasMetaChange = false %}

    {% for source in [meta, props] %}
        {% if source %}
            {% for f in source %}
                {% if f.status is defined and f.status != 'same' %}
                    {% set hasMetaChange = true %}
                {% endif %}
            {% endfor %}
        {% endif %}
    {% endfor %}

    {% set opEff = (op == 'unchanged' and hasMetaChange) ? 'modified' : op %}
    {% set wrapperClass = diff.wrapper_class(opEff) %}
    {% set renderKey = row.render_key is defined ? row.render_key : null %}

    <div class="{{ wrapperClass }} {% if row.body_html is defined and row.body_html %}diff-inline{% endif %}">
        <div class="mb-2">
            {% if opEff == 'added' %}
                <span class="badge bg-success text-white">{{ 'Added'|trans({}, 'admin') }}</span>
            {% elseif opEff == 'removed' %}
                <span class="badge bg-danger text-white">{{ 'Removed'|trans({}, 'admin') }}</span>
            {% elseif opEff == 'modified_text' %}
                <span class="badge bg-warning text-black">{{ 'Changed text'|trans({}, 'admin') }}</span>
            {% elseif opEff == 'modified' %}
                <span class="badge bg-warning text-black">{{ 'Changed'|trans({}, 'admin') }}</span>
            {% else %}
                <span class="badge bg-secondary text-white">{{ 'Unchanged'|trans({}, 'admin') }}</span>
            {% endif %}

            {% if blockAuthors is defined and renderKey and blockAuthors[renderKey] is defined and blockAuthors[renderKey]|length > 0 %}
                <div class="d-inline-flex align-items-center gap-1 ms-2 small text-muted">
                    {% for email in blockAuthors[renderKey] %}
                        {% set user = usersData[email]|default({}) %}
                        <span
                            class="avatar avatar-xs"
                            {% if user.avatar|default('') %}
                            style="background-image: url({{ user.avatar }})"
                            {% endif %}
                            title="{{ user.name|default(email) }}"
                        ></span>
                    {% endfor %}
                    <span>{{ blockAuthors[renderKey]|map(e => usersData[e].name|default(e))|join(', ') }}</span>
                </div>
            {% endif %}
        </div>

        {% if row.kind == 'paragraph' %}
            {{ include('@XutimCore/admin/content_fragment/paragraph.html.twig', {row: row}) }}
        {% elseif row.kind == 'heading' %}
            {{ include('@XutimCore/admin/content_fragment/header.html.twig', {row: row}) }}
        {% elseif row.kind == 'quote' %}
            {{ include('@XutimCore/admin/content_fragment/quote.html.twig', {row: row, meta: meta}) }}
        {% elseif row.kind == 'list' %}
            {{ include('@XutimCore/admin/content_fragment/list.html.twig', {row: row}) }}
        {% elseif row.kind == 'image' or row.kind == 'xutimImage' %}
            {{ include('@XutimCore/admin/content_fragment/diff/xutim_image_diff.html.twig', {row: row, meta: meta, op: opEff}) }}
        {% elseif row.kind == 'file' or row.kind == 'xutimFile' %}
            {{ include('@XutimCore/admin/content_fragment/diff/xutim_file_diff.html.twig', {row: row, meta: meta, op: opEff, locale: locale}) }}
        {% elseif row.kind == 'image_gallery' or row.kind == 'imageRow' %}
            {{ include('@XutimCore/admin/content_fragment/diff/image_row_diff.html.twig', {row: row, meta: meta, op: opEff}) }}
        {% elseif row.kind == 'page_link' or row.kind == 'article_link' or row.kind == 'tag_link' or row.kind == 'pageLink' or row.kind == 'articleLink' or row.kind == 'xutimTag' %}
            {{ include('@XutimCore/admin/content_fragment/diff/link_diff.html.twig', {row: row, meta: meta, op: opEff}) }}
        {% elseif row.kind == 'hero_heading' or row.kind == 'mainHeader' %}
            {{ include('@XutimCore/admin/content_fragment/diff/main_header_diff.html.twig', {row: row, meta: meta, op: opEff}) }}
        {% elseif row.kind == 'embed' %}
            {{ include('@XutimCore/admin/content_fragment/diff/embed_diff.html.twig', {row: row, meta: meta, op: opEff}) }}
        {% elseif row.kind == 'snippet' or row.kind == 'block' %}
            {{ include('@XutimCore/admin/content_fragment/diff/code_block_diff.html.twig', {row: row, meta: meta, op: opEff}) }}
        {% elseif row.kind == 'delimiter' %}
            {{ include('@XutimCore/admin/content_fragment/delimiter.html.twig') }}
        {% elseif row.kind == 'foldable_start' %}
            {{ include('@XutimCore/admin/content_fragment/foldable_start.html.twig', {row: row}) }}
        {% elseif row.kind == 'foldable_end' %}
            {{ include('@XutimCore/admin/content_fragment/foldable_end.html.twig') }}
        {% else %}
            <div class="small text-muted mb-1">
                {{ 'Unknown block'|trans({}, 'admin') }}
            </div>
            <div class="small text-muted">
                <strong>{{ row.attrs.sourceType ?? 'unknown' }}</strong>
                {% if row.attrs.reason is defined and row.attrs.reason %}
                    <span class="ms-2">{{ row.attrs.reason }}</span>
                {% endif %}
            </div>
            {% if row.raw_summary is defined and row.raw_summary %}
                <pre class="small text-secondary mb-0">{{ row.raw_summary }}</pre>
            {% endif %}
        {% endif %}

        {{ diff.tune_changes(props) }}
    </div>
{% endfor %}
