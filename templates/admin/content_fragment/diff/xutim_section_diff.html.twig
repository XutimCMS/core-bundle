{% macro value(display) %}
    {% import _self as field %}
    {% if display.kind == 'empty' %}
        <span class="text-secondary">—</span>
    {% elseif display.kind == 'image' %}
        <span class="d-inline-flex align-items-center gap-2">
            <img
                src="{{ media_url(display.media, 'thumb_small') }}"
                alt=""
                class="img-thumbnail"
                style="max-width: 80px; height: auto"
            >
            {% if display.editUrl is defined %}
                <a href="{{ display.editUrl }}" target="_blank" rel="noopener">{{ display.text }}</a>
            {% else %}
                {{ display.text }}
            {% endif %}
        </span>
    {% elseif display.kind == 'entity' or display.kind == 'file' %}
        {% if display.editUrl is defined %}
            <a href="{{ display.editUrl }}" target="_blank" rel="noopener">{{ display.text }}</a>
        {% else %}
            {{ display.text }}
        {% endif %}
        {% if display.typeLabel is defined %}
            <span class="badge bg-secondary-lt ms-1">{{ display.typeLabel }}</span>
        {% endif %}
    {% elseif display.kind == 'url' %}
        <a href="{{ display.text }}" target="_blank" rel="noopener">{{ display.text }}</a>
    {% elseif display.kind == 'html' %}
        {{ display.text|raw }}
    {% elseif display.kind == 'list' %}
        {% for item in display.items %}
            <div>{{ field.value(item) }}</div>
        {% else %}
            <span class="text-secondary">—</span>
        {% endfor %}
    {% elseif display.kind == 'missing' %}
        <code>{{ display.text }}</code>
        <span class="text-secondary">{{ 'not found'|trans({}, 'admin') }}</span>
    {% else %}
        {{ display.text }}
    {% endif %}
{% endmacro %}

{% import _self as field %}

<div class="xutim-section-diff">
    <div class="small text-muted mb-2">
        {% if row.section_code_changed %}
            <span class="badge bg-purple-lt">{{ 'Section'|trans({}, 'admin') }}</span>
            <del class="text-danger">{{ xutim_section_name(row.old_section_code) }}</del>
            →
            <ins class="text-success">{{ xutim_section_name(row.section_code) }}</ins>
        {% else %}
            <span class="badge bg-purple-lt">{{ xutim_section_name(row.section_code) }}</span>
        {% endif %}
    </div>

    <dl class="row mb-0">
        {% for fieldName in row.fields %}
            {% set fieldMeta = row.meta[fieldName] ?? null %}
            {% set fieldPart = row.parts[fieldName] ?? null %}
            {% set fieldStatus = fieldMeta.status ?? 'same' %}

            <dt class="col-sm-3 text-truncate small fw-semibold">
                {{ fieldName }}
                {% if fieldStatus == 'changed' %}
                    <span class="badge bg-warning-lt ms-1">{{ 'changed'|trans({}, 'admin') }}</span>
                {% endif %}
            </dt>
            <dd class="col-sm-9">
                {% if fieldPart is not null and fieldPart.kind == 'text' %}
                    <div class="diff-inline">{{ fieldPart.html|raw }}</div>
                {% elseif fieldPart is not null and fieldPart.kind == 'ref' %}
                    {% if fieldStatus == 'changed' %}
                        <del class="text-danger">{{ field.value(xutim_section_diff_field(row.old_section_code, fieldName, fieldMeta.old_raw ?? null, app.locale)) }}</del>
                        →
                        <ins class="text-success">{{ field.value(xutim_section_diff_field(row.section_code, fieldName, fieldMeta.new_raw ?? null, app.locale)) }}</ins>
                    {% else %}
                        {{ field.value(xutim_section_diff_field(row.section_code, fieldName, fieldMeta.new_raw ?? null, app.locale)) }}
                    {% endif %}
                {% endif %}
            </dd>
        {% endfor %}
    </dl>
</div>
